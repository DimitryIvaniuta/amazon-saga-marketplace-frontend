{
  "name": "amazon-saga-marketplace-frontend",
  "version": "1.1.0",
  "private": true,
  "description": "Production-grade React 19.2 marketplace portal with runtime-validated APIs, idempotent Saga checkout, operations tooling, accessibility, and observability.",
  "type": "module",
  "engines": {
    "node": ">=22.22.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "check": "npm run verify:structure && npm run lint && npm run typecheck && npm run test && npm run build && npm run verify:bundle",
    "verify:structure": "node scripts/verify-structure.mjs",
    "e2e:list": "playwright test --list",
    "verify:bundle": "node scripts/check-bundle.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:sbom": "npm sbom --sbom-format=cyclonedx --omit=dev > sbom.cdx.json",
    "build:verified": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@tanstack/react-query": "5.101.0",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-router": "8.0.1",
    "web-vitals": "5.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
